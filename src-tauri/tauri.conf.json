{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Othello Island",
  "version": "0.1.0",
  "identifier": "com.kinowill.othelloisland",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Othello Island",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}

