{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Othello Island",
  "version": "0.1.5",
  "identifier": "com.kinowill.othelloisland",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Othello Island",
        "width": 1600,
        "height": 900,
        "minWidth": 1600,
        "minHeight": 900,
        "maxWidth": 1600,
        "maxHeight": 900,
        "fullscreen": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "windows/nsis-hooks.nsh"
      }
    }
  }
}
